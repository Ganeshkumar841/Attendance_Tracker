# ===== SECURITY SETTINGS =====
# Session timeout in milliseconds (default: 30 minutes)
SESSION_TIMEOUT_MS=1800000

# Maximum login attempts before rate limiting (default: 5)
MAX_LOGIN_ATTEMPTS=5

# Login attempt window in milliseconds (default: 15 minutes)
LOGIN_ATTEMPT_WINDOW_MS=900000

# ===== FILE UPLOAD SETTINGS =====
# Maximum file size for CSV uploads in MB (default: 5)
MAX_FILE_SIZE_MB=5

# ===== PAGINATION SETTINGS =====
# Number of attendance records per page (default: 50)
ATTENDANCE_PAGE_SIZE=50

# ===== FEATURE FLAGS =====
# Enable real-time synchronization
ENABLE_LIVE_SYNC=true

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# ===== DEBUG SETTINGS =====
# Enable debug logging to console
DEBUG=false
